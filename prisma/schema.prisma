generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  firstName    String?
  lastName     String?
  mobile       String?
  password     String
  role         String       @default("STUDENT")
  status       String       @default("PENDING")
  isSuperAdmin Boolean      @default(false)
  createdAt    DateTime     @default(now())
  batchId      String?

  submissions      Submission[]
  attemptOverrides AttemptOverride[]
  bannedFrom       BannedStudent[]
  nameChangeRequests NameChangeRequest[]
  adminLogs        AdminLog[]
  batch            Batch? @relation(fields: [batchId], references: [id])
}

model Exam {
  id              String       @id @default(uuid())
  title           String
  description     String?
  durationMinutes Int
  startTime       DateTime?
  endTime         DateTime?
  upcomingDays    Int          @default(10)
  createdById     String?
  createdAt       DateTime     @default(now())
  fullscreenChances Int        @default(5)
  maxAttempts     Int          @default(1)

  leaderboardFrozen    Boolean @default(false)
  leaderboardAnonymous Boolean @default(false)
  isDraft              Boolean @default(false)

  questions       Question[]
  submissions     Submission[]
  overrides       AttemptOverride[]
  bannedStudents  BannedStudent[]
  batches         Batch[]
}

model Question {
  id              String       @id @default(uuid())
  examId          String
  text            String
  type            String
  section         String       @default("General")
  mediaUrl        String?
  maxMarks        Float        @default(1)
  createdAt       DateTime     @default(now())

  exam            Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  options         Option[]

  correctNumeric  Float?
  correctText     String?
  explanation     String?

  answers         SubmissionAnswer[]
}

model Option {
  id          String   @id @default(uuid())
  questionId  String
  text        String
  isCorrect   Boolean  @default(false)

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Submission {
  id          String   @id @default(uuid())
  examId      String
  userId      String
  score       Float?
  maxScore    Float?
  submittedAt DateTime @default(now())
  
  status      String   @default("COMPLETED")
  timeLeft    Int?
  fullscreenExitCount Int @default(0)

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers     SubmissionAnswer[]
}

model SubmissionAnswer {
  id             String     @id @default(uuid())
  submissionId   String
  questionId     String

  selectedOptionIds String?
  numericAnswer     Float?
  textAnswer        String?
  marksObtained     Float?
  timeSpent         Int?

  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question       Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model AttemptOverride {
  id              String   @id @default(uuid())
  examId          String
  userId          String
  allowedAttempts Int
  durationOverride Int?
  endTimeOverride  DateTime?
  createdAt       DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
}

model BannedStudent {
  id        String   @id @default(uuid())
  examId    String
  userId    String
  createdAt DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([examId, userId])
}

model Batch {
  id        String   @id @default(uuid())
  name      String   @unique
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  users     User[]
  exams     Exam[]
}

model NameChangeRequest {
  id           String   @id @default(uuid())
  userId       String
  newFirstName String
  newLastName  String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminLog {
  id        String   @id @default(uuid())
  userId    String?
  message   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}
