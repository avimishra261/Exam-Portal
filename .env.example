# ==============================================
# Exam Portal — Environment Variables
# ==============================================
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ---- Database ----
# SQLite (default for local development)
DATABASE_URL="file:./dev.db"

# ---- Authentication ----
# REQUIRED in production. Must be a cryptographically random string (min 32 chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ---- Google Gemini AI ----
# Required for AI-powered features (descriptive answer grading, performance insights).
# Get your API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
